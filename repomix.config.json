{
    "$schema": "https://repomix.com/schemas/latest/schema.json",
    "input": {
        "maxFileSize": 52428800
    },
    "output": {
        "filePath": "repomix-output.xml",
        "style": "xml",
        "parsableStyle": false,
        "fileSummary": true,
        "directoryStructure": true,
        "includeFullDirectoryStructure": true,
        "files": true,
        "removeComments": false,
        "removeEmptyLines": false,
        "compress": false,
        "topFilesLength": 5,
        "showLineNumbers": true,
        "truncateBase64": false,
        "copyToClipboard": false,
        "tokenCountTree": true,
        "git": {
            "sortByChanges": false,
            "sortByChangesMaxCommits": 50,
            "includeDiffs": false,
            "includeLogs": false,
            "includeLogsCount": 159
        },
        "instructionFilePath": "repomix-instructions.md",
    },
    "include": [
        "Documentation/**/*.md",
        "Assets/**/*.cs",
        "Assets/**/*.json",
        "Assets/Shaders/**/*.shader",
        "Assets/Shaders/**/*.hlsl",
        "Assets/Data/**/*.asset"
    ],
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": []
    },
    "security": {
        "enableSecurityCheck": true
    },
    "tokenCount": {
        "encoding": "o200k_base"
    }
}
