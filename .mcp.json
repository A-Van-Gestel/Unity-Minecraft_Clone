{
  "mcpServers": {
    "unity-api": {
      "command": "uvx",
      "args": [
        "unity-api-mcp"
      ],
      "env": {
        "UNITY_PROJECT_PATH": "ProjectSettings/ProjectVersion.txt"
      }
    },
    "code-review-graph": {
      "command": "uvx",
      "args": [
        "code-review-graph",
        "serve"
      ],
      "type": "stdio"
    }
  }
}
