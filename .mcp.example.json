{
  "mcpServers": {
    "unity-api": {
      "command": "uvx",
      "args": [
        "unity-api-mcp"
      ],
      "env": {
        "UNITY_PROJECT_PATH": "ProjectSettings/ProjectVersion.txt"
      }
    },
	"unity-mcp": {
      "command": "C:\\Users\\axelv\\.unity\\relay\\relay_win.exe",
      "args": ["--mcp"]
    },
    "code-review-graph": {
      "command": "uvx",
      "args": [
        "code-review-graph",
        "serve"
      ],
      "type": "stdio",
      "disabled": true
    }
  }
}
